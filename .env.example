# Copy to .env and fill in (never commit .env)
# See spec/documents/CI_CD_AND_SECRETS.md

# --- Expo / app (safe to mirror in EAS / GitHub Actions as EXPO_PUBLIC_*) ---
EXPO_PUBLIC_USER_POOL_ID=
EXPO_PUBLIC_USER_POOL_CLIENT_ID=
EXPO_PUBLIC_OAUTH_DOMAIN=
EXPO_PUBLIC_API_ENDPOINT=

# --- Local / scripts only (NOT EXPO_PUBLIC — do not ship to client bundle) ---
# Used by backend sync script to merge into AWS Secrets Manager LLM JSON (openai key).
OPENAI_API_KEY=

# Backend / feature flags (local; production Lambdas use env from Terraform)
USE_AI_GENERATION=false
